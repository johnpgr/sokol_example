If:
  PathMatch: src/.*\.(c|h)$
CompileFlags:
  Add:
    - -xc
    - -std=c11
    - -D_POSIX_C_SOURCE=200809L
    - -DAPP_WIDTH=1280
    - -DAPP_HEIGHT=720
    - -I.
    - -I../generated
    - -I../thirdparty

---

If:
  PathMatch: generated/.*\.h$
CompileFlags:
  Add:
    - -xc
    - -std=c11
    - -D_POSIX_C_SOURCE=200809L
    - -I.
    - -I../src
    - -I../thirdparty
